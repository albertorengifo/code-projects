{
  "name": "todo-list-codex-experiment",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace @todo-list/web",
    "dev:api": "npm run dev --workspace @todo-list/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
